# App
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
PUBLIC_BASE_URL=https://bot.yourdomain.com
PUBLIC_TOUR_URL=https://your-public-site.com/experiences/emerald-mining-tour

# WhatsApp Business Cloud API
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=change-me
WHATSAPP_APP_SECRET=change-me
WHATSAPP_PHONE_NUMBER_ID=change-me
WHATSAPP_BUSINESS_ACCOUNT_ID=change-me
WHATSAPP_GRAPH_API_VERSION=v24.0

# Owner identity (used in skill files + system prompt via {{OWNER_NAME}} / {{PARTNER_NAME}} substitution)
OWNER_NAME=change-me
PARTNER_NAME=change-me

# Owner alert
OWNER_PERSONAL_WHATSAPP_NUMBER=573001112233
ALERT_CHANNEL=telegram
HOT_LEAD_THRESHOLD=85
URGENT_LEAD_THRESHOLD=95
MAX_OWNER_WHATSAPP_ALERTS_PER_CUSTOMER_PER_DAY=1

# Telegram optional low-cost alert
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DeepSeek optional fallback
AI_ENABLED=true
DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_OUTPUT_TOKENS=180
DEEPSEEK_TEMPERATURE=0.2

# AI budget controls
DAILY_AI_BUDGET_USD=0.20
MONTHLY_AI_BUDGET_USD=5.00
MAX_AI_CALLS_PER_CUSTOMER_PER_DAY=3
MAX_AI_CALLS_GLOBAL_PER_DAY=100
AI_CACHE_TTL_SECONDS=604800

# WhatsApp cost controls
SEND_IMAGES_ENABLED=true
MAX_IMAGES_PER_CUSTOMER_PER_72H=1
MAX_BOT_MESSAGES_PER_CUSTOMER_PER_HOUR=8
MAX_BOT_MESSAGES_PER_CUSTOMER_PER_DAY=20
ALLOW_CUSTOMER_REENGAGEMENT_TEMPLATES=false

# SQLite
SQLITE_PATH=./data/bot.sqlite

# Admin
ADMIN_SECRET=change-me

# Logging
LOG_LEVEL=info
