# App
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
PUBLIC_BASE_URL=https://bot.yourdomain.com
PUBLIC_TOUR_URL=https://your-public-site.com/experiences/emerald-mining-tour

# WhatsApp Business Cloud API
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=change-me
WHATSAPP_APP_SECRET=change-me
WHATSAPP_PHONE_NUMBER_ID=change-me
WHATSAPP_BUSINESS_ACCOUNT_ID=change-me
WHATSAPP_GRAPH_API_VERSION=v24.0

# Owner identity (used in skill files + system prompt via {{OWNER_NAME}} / {{PARTNER_NAME}} substitution)
OWNER_NAME=change-me
PARTNER_NAME=change-me

# Owner alert
OWNER_PERSONAL_WHATSAPP_NUMBER=573000000000
ALERT_CHANNEL=telegram
HOT_LEAD_THRESHOLD=85
URGENT_LEAD_THRESHOLD=95
MAX_OWNER_WHATSAPP_ALERTS_PER_CUSTOMER_PER_DAY=1

# Telegram optional low-cost alert
TELEGRAM_BOT_TOKEN=
# Fallback Telegram chat used ONLY when LEAD_ROUTING_JSON is empty (single-line mode).
TELEGRAM_CHAT_ID=

# Multi-line lead routing (optional). Leave empty for single-line mode.
# Hot-lead alerts and conversation access are scoped per sales line:
#   - "weight" = percentage split of hot leads (sticky per customer, normalized).
#   - "type=bridge"   -> agent replies through the API line via Telegram (/chat).
#                        Use the API line (WHATSAPP_PHONE_NUMBER_ID above).
#   - "type=referral" -> bot tells the customer the agent will contact them from
#                        "displayNumber"; that agent replies from their own
#                        WhatsApp Business app (not the bridge).
#   - "telegramChatId" must be UNIQUE per line; an agent only sees alerts +
#                        conversations for their own assigned leads. /report counts
#                        are global (all lines) and visible to every agent.
# {{OWNER_NAME}} / {{PARTNER_NAME}} are substituted from the env vars above.
#
# Example: line 1 = your API line (bridge, 30%); line 2 = partner referral (70%):
# LEAD_ROUTING_JSON={"salesLines":[{"id":"line1_bridge","type":"bridge","label":"ANDEAN SCAPES BOOKING","weight":30,"telegramChatId":"111111111","agentName":"{{OWNER_NAME}}"},{"id":"line2_referral","type":"referral","label":"ANDEAN SCAPES BOOKING","weight":70,"displayNumber":"+573001112233","telegramChatId":"222222222","agentName":"{{PARTNER_NAME}}"}]}
LEAD_ROUTING_JSON=

# DeepSeek optional fallback
AI_ENABLED=true
DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_OUTPUT_TOKENS=450
DEEPSEEK_TEMPERATURE=0.35

# AI budget controls
DAILY_AI_BUDGET_USD=1.00
MONTHLY_AI_BUDGET_USD=20.00
MAX_AI_CALLS_PER_CUSTOMER_PER_DAY=12
MAX_AI_CALLS_GLOBAL_PER_DAY=300
AI_CACHE_TTL_SECONDS=604800

# WhatsApp cost controls
SEND_IMAGES_ENABLED=true
MAX_IMAGES_PER_CUSTOMER_PER_72H=1
MAX_BOT_MESSAGES_PER_CUSTOMER_PER_HOUR=18
MAX_BOT_MESSAGES_PER_CUSTOMER_PER_DAY=40
ALLOW_CUSTOMER_REENGAGEMENT_TEMPLATES=false

# SQLite
SQLITE_PATH=./data/bot.sqlite

# Dynamic pricing & availability (Cloudflare R2)
# Leave empty to use static defaults from andean-scapes.skill.json
DYNAMIC_SKILL_URL=
# How often to re-fetch from R2 (milliseconds). Default: 5000
DYNAMIC_SKILL_REFRESH_MS=5000

# Logging
LOG_LEVEL=info
